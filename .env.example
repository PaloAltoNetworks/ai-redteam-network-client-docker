# Palo Alto AI Red Teaming Network Client - Configuration
# Copy this file to .env and fill in your values from the portal.
#
# Portal: https://ai-red-teaming.paloaltonetworks.com

# --- Registry credentials (from Channel Setup > Step 2) ---
REGISTRY_USERNAME=""
REGISTRY_PASSWORD=""

# --- Service account (from Channel Setup > Step 3) ---
CLIENT_ID=""
CLIENT_SECRET=""

# --- Channel config (from Channel Setup > Step 4) ---
CHANNEL_ID=""

# --- Tenant path (extracted from OCI URL in Step 4) ---
# Example: pairs-redteam-prd-fckx/red-teaming-onprem
TENANT_PATH=""

# --- Chart version ---
# Use "latest" for auto-detection, or pin a specific version (e.g. "1.0.4")
CHART_VERSION="latest"
