# Palo Alto AI Red Teaming Network Client - Configuration
# Copy this file to .env and fill in your values from the portal.
# Or run: ./setup-panw-network-client.sh --init  (recommended — only needs 3 inputs!)
#
# Portal: https://ai-red-teaming.paloaltonetworks.com

# --- Service account (from Channel Setup > Service Account) ---
CLIENT_ID=""
CLIENT_SECRET=""

# --- TSG ID (auto-extracted from CLIENT_ID during --init) ---
# Format: the numeric part from name@<tsg_id>.iam.panserviceaccount.com
TSG_ID=""

# --- Channel (auto-selected during --init) ---
CHANNEL_ID=""

# --- Region (selected during --init) ---
# Available: us, nl, sg
#   us = registry.ai-red-teaming.paloaltonetworks.com        Americas (US)
#   nl = registry-nl.ai-red-teaming.paloaltonetworks.com     Europe (Netherlands)
#   sg = registry-sg.ai-red-teaming.paloaltonetworks.com     Asia Pacific (Singapore)
REGION="us"

# --- Registry token (auto-fetched during --init from API) ---
# Long-lived (~1 year). Refreshed automatically if expired.
# REGISTRY_TOKEN=""
# REGISTRY_TOKEN_EXPIRY=""

# --- Runtime config (container environment, optional overrides) ---
# LOG_LEVEL="INFO"
# PRETTY_LOGS="false"
# HANDSHAKE_TIMEOUT="10s"
# PROXY_TIMEOUT="100s"
# CONNECTION_RETRY_INTERVAL="5s"
# POOL_SIZE="2048"
# RE_AUTH_INTERVAL="5m"

# --- Custom SSL (for self-signed or internal CA certificates) ---
# Set to "true" for on-premises/private cloud with self-signed certs.
# Not required for production environments with valid SSL certificates.
# DISABLE_SSL_VERIFICATION="true"

# --- Proxy configuration ---
# HTTP_PROXY="http://proxy.example.com:8080"
# HTTPS_PROXY="http://proxy.example.com:8080"
# NO_PROXY="localhost,127.0.0.1"

# --- Advanced overrides (rarely needed) ---
# IMAGE_PATH=""          # Override API-discovered image (format: path/image:tag)
# REGISTRY_HOST=""       # Override region-based registry hostname
